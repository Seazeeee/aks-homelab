# Serves the prebuilt Hugo site. Listens on 8080 (unprivileged) so the
# container can run non-root in the cluster.
:8080 {
	root * /usr/share/caddy
	encode zstd gzip

	header {
		# Static site, zero JavaScript: scripts/objects/frames all denied.
		# Styles are the fingerprinted local bundle + Google Fonts CSS.
		Content-Security-Policy "default-src 'none'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	route {
		# Canonicalize the explicit index file to the root URL
		redir /index.html / 301
		file_server
	}

	handle_errors {
		# Re-assert the security headers so error responses carry them too.
		header {
			Content-Security-Policy "default-src 'none'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
			X-Frame-Options "DENY"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
		}
		@404 expression {http.error.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
}
